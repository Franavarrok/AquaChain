# URL base de la API REST del backend. El cliente de Socket.io (src/realtime/socket.ts)
# reutiliza esta misma URL quitándole el segmento "/api", así que NO hace falta
# una variable separada para el WebSocket.
#
# Desarrollo local:
VITE_API_URL=http://localhost:4000/api

# Producción (Vercel) — reemplazar por la URL real del backend en Render:
# VITE_API_URL=https://aquachain-backend.onrender.com/api
