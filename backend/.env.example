# ── Entorno ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Base de datos (Neon Serverless Postgres) ────────────────────────────
# En local podés usar tu Postgres de Docker Compose:
# DATABASE_URL=postgresql://aquachain:aquachain@localhost:5432/aquachain
# En Render, pegá la "Connection string" que te da Neon (incluye sslmode=require):
# DATABASE_URL=postgresql://usuario:password@ep-xxxx.neon.tech/aquachain?sslmode=require
DATABASE_URL=postgresql://aquachain:aquachain@localhost:5432/aquachain

# ── CORS ──────────────────────────────────────────────────────────────────
# Lista separada por comas de orígenes autorizados a consumir la API y conectar
# por Socket.io. En producción, poné la URL real de tu deploy en Vercel.
# Ejemplo: CORS_ALLOWED_ORIGINS=https://aquachain.vercel.app,https://aquachain-git-main.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://aqua-chain.vercel.app

# ── Simulador de sensores ─────────────────────────────────────────────────
SENSOR_INTERVAL_MS=5000
ANOMALY_PROBABILITY=0.15
SENSOR_AUTOSTART=true

# ── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
